{
  "name": "bunigniter",
  "version": "1.0.0",
  "description": "CodeIgniter 3-style Full Stack MVC Framework for Bun + Elysia + Rendu",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot system/core/bootstrap.ts",
    "start": "bun run system/core/bootstrap.ts",
    "migrate": "bun run database/migrate.ts",
    "igniter": "bun run cli/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "elysia": "2.0.0-exp.25",
    "rendu": "^0.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
