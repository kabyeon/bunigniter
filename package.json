{
	"name": "bunigniter",
	"version": "0.6.1",
	"description": "CodeIgniter 3-style Full Stack MVC Framework for Bun",
	"type": "module",
	"bin": {
		"bi": "cli/index.ts"
	},
	"exports": {
		".": "./system/core/index.ts",
		"./core/*": "./system/core/*.ts",
		"./helpers/*": "./system/helpers/*.ts",
		"./cli": "./cli/index.ts",
		"./bootstrap": "./system/core/bootstrap.ts"
	},
	"files": [
		"system/",
		"cli/",
		"public/css/style.css",
		"public/js/app.js",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"dev": "bun run --hot system/core/bootstrap.ts",
		"start": "bun run system/core/bootstrap.ts",
		"migrate": "bun run database/migrate.ts",
		"bi": "bun run cli/index.ts",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write ."
	},
	"dependencies": {},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/bun": "latest"
	},
	"keywords": [
		"bun",
		"codeigniter",
		"mvc",
		"framework",
		"fullstack",
		"typescript",
		"sqlite",
		"web-framework",
		"bunigniter"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kabyeon/bunigniter.git"
	},
	"homepage": "https://github.com/kabyeon/bunigniter",
	"engines": {
		"bun": ">=1.0.0"
	}
}
